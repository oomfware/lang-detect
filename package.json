{
	"name": "@oomfware/lang-detect",
	"version": "0.2.1",
	"description": "natural language detection library",
	"license": "0BSD",
	"repository": {
		"type": "git",
		"url": "https://codeberg.org/oomfware/lang-detect"
	},
	"files": [
		"dist/",
		"src/",
		"weights/",
		"!src/**/*.bench.ts",
		"!src/**/*.test.ts"
	],
	"type": "module",
	"types": "./dist/index.d.ts",
	"imports": {
		"#load": {
			"source": "./src/nn/load.node.ts",
			"node": "./dist/nn/load.node.js",
			"default": "./dist/nn/load.js"
		}
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"fmt": "oxfmt",
		"lint": "oxlint",
		"eval": "node --conditions source src/eval.ts",
		"test": "node --test --conditions source src/**/*.test.ts",
		"prepublish": "rm -rf dist; pnpm run build",
		"download-dataset": "cd train && bash download_dataset.sh",
		"train": "cd train && uv run train.py -e lean_v5",
		"export": "cd train && uv run export.py -e lean_v5 -o ../weights/standard"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"bumpp": "^11.0.1",
		"lande": "^1.0.10",
		"oxfmt": "^0.45.0",
		"oxlint": "^1.60.0",
		"oxlint-tsgolint": "^0.21.1",
		"typescript": "^6.0.3"
	}
}
