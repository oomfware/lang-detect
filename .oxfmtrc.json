{
	"$schema": "https://unpkg.com/oxfmt/configuration_schema.json",
	"trailingComma": "all",
	"useTabs": true,
	"tabWidth": 2,
	"printWidth": 110,
	"semi": true,
	"singleQuote": true,
	"bracketSpacing": true,
	"sortImports": {
		"groups": [["builtin"], ["external"], ["parent"], ["sibling", "index"]]
	},
	"overrides": [
		{
			"files": ["tsconfig.json"],
			"options": { "parser": "jsonc" }
		},
		{
			"files": ["*.md"],
			"options": { "printWidth": 100, "proseWrap": "always" }
		}
	]
}
